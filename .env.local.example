# Keystatic storage mode
# Set to 'github' in production (Vercel environment variables)
# Leave unset or set to 'local' for local development
KEYSTATIC_STORAGE_KIND=local

# GitHub storage (required when KEYSTATIC_STORAGE_KIND=github)
# Obtain from Keystatic Cloud dashboard: https://keystatic.com
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=

# GitHub repository details (required when KEYSTATIC_STORAGE_KIND=github)
GITHUB_REPO_OWNER=blendstrup
GITHUB_REPO_NAME=by-blendstrup-frontend

# Resend transactional email
# Get your API key from: resend.com → API Keys → Create API Key
RESEND_API_KEY=

# The email address that receives inquiry notifications (owner's email)
RECIPIENT_EMAIL=

# The 'from' sender address — must use a Resend-verified domain.
# Use onboarding@resend.dev for local testing before DNS setup.
# After DNS records are added and domain is verified: noreply@[your-domain]
RESEND_FROM_ADDRESS=onboarding@resend.dev
